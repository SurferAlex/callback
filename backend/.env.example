HTTP_ADDR=:8080
DATABASE_URL=postgres://postgres:postgres@postgres:5432/vpn?sslmode=disable
INTERNAL_TOKEN=change-me
TELEGRAM_BOT_TOKEN=your-user-bot-token-from-botfather
DEFAULT_VPN_SERVER_ID=default
DEFAULT_MAX_IPS=2

# Primary panel (server id "default", synced on every API start)
XUI_BASE_URL=https://panel.example.com:39821/your-path
XUI_USERNAME=admin
XUI_PASSWORD=change-me
XUI_INBOUND_ID=1
XUI_EXTERNAL_HOST=panel.example.com
XUI_FINGERPRINT=chrome
XUI_SPIDERX=/
XUI_FLOW=xtls-rprx-vision
XUI_HOST_HEADER=
XUI_SERVER_NAME=
XUI_INSECURE_SKIP_VERIFY=0

# Second panel (insert once if id "vps_1" is missing; omit block to disable)
VPN_SERVER_VPS1_ID=vps_1
VPN_SERVER_VPS1_NAME=VPS 1
VPN_SERVER_VPS1_XUI_BASE_URL=https://surfervpn.space:39821/golang-dev-3x-surfer
