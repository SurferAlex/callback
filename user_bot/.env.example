TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
VPNAPI_BASE_URL=http://vpnapi:8080
# Read-only access for subscription expiry notifications (same as backend)
DATABASE_URL=postgres://postgres:postgres@postgres:5432/vpn?sslmode=disable
NOTIFY_SCHEDULER_ENABLED=true
NOTIFY_SCHEDULER_INTERVAL=30m
# Must match INTERNAL_TOKEN in backend/.env
VPNAPI_INTERNAL_TOKEN=change-me
MINI_APP_URL=https://app.surfwave.space

PLAN_PRICE_1M=299
PLAN_PRICE_3M=799
PLAN_PRICE_6M=1490
PLAN_PRICE_12M=2490

WELCOME_STICKER_ID=
SUCCESS_STICKER_ID=
ERROR_STICKER_ID=

SUPPORT_CONTACT=@surfervpn_support
SUPPORT_TELEGRAM_URL=https://t.me/surfervpn_support
